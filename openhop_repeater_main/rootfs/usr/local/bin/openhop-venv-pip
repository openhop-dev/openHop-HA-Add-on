#!/bin/sh
set -eu

VENV_PYTHON="$(dirname "$0")/python"
BRANCH_HELPER="${OPENHOP_ADDON_BRANCH_HELPER:-/usr/local/lib/openhop-addon/branch_state.py}"

if [ ! -x "${VENV_PYTHON}" ]; then
    printf '%s\n' "openHop update environment is missing its Python interpreter" >&2
    exit 1
fi
if [ ! -r "${BRANCH_HELPER}" ]; then
    printf '%s\n' "openHop branch validation helper is unavailable" >&2
    exit 1
fi

if ! "${VENV_PYTHON}" "${BRANCH_HELPER}" validate-pip-args "$@"; then
    printf '%s\n' "Refusing an unsafe or unexpected openHop branch installation request" >&2
    exit 2
fi

exec "${VENV_PYTHON}" -m pip "$@"
